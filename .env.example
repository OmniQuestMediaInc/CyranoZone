# Cyrano™ — Environment Variable Template
# ============================================================================
# Copy to .env (or .env.local) and fill in real values. NEVER commit a populated
# .env file. Variables marked REQUIRED have no default — docker-compose will
# fail to start without them. Variables marked OPTIONAL have a safe default in
# code; setting them only matters in production or staging.
#
# Generate any secret with: openssl rand -hex 32
# ============================================================================

# ── Runtime ─────────────────────────────────────────────────────────────────
NODE_ENV=development
API_PORT=3000
# OPTIONAL. Logger verbosity for NestJS / structured logs.
# One of: error | warn | log | debug | verbose. Defaults to 'log'.
LOG_LEVEL=log
# OPTIONAL. Public origin of the user-facing frontend (used in Stripe success
# / cancel URLs, email links, CORS allowlists). Set per environment.
FRONTEND_URL=http://localhost:3100

# ── Database (Postgres) ─────────────────────────────────────────────────────
# REQUIRED. Used by docker-compose to bring up the db container and by Prisma.
POSTGRES_DB=cyrano
POSTGRES_USER=cyrano_app
DB_PASSWORD=

# DATABASE_URL is consumed by Prisma + NestJS. When running via docker-compose
# the api container builds it from POSTGRES_USER/DB_PASSWORD/POSTGRES_DB. For
# local `yarn prisma migrate dev` runs against a host port, set it explicitly.
DATABASE_URL=postgresql://cyrano_app:${DB_PASSWORD}@localhost:5432/${POSTGRES_DB}

# ── Cache + queue (Redis) ───────────────────────────────────────────────────
# REQUIRED.
REDIS_PASSWORD=
REDIS_URL=redis://:${REDIS_PASSWORD}@localhost:6379
# OPTIONAL — legacy host/port pair used by Bull queue config in some services.
# Prefer REDIS_URL above; these two are kept for backwards compatibility.
REDIS_HOST=localhost
REDIS_PORT=6379

# ── Real-time fabric (NATS) ─────────────────────────────────────────────────
NATS_URL=nats://localhost:4222

# ── Module feature flags (default ON in production) ─────────────────────────
LEDGER_ENABLED=true
GATEGUARD_ENABLED=true
RECOVERY_ENABLED=true
DIAMOND_CONCIERGE_ENABLED=true
FFS_ENABLED=true
CREATOR_CONTROL_ENABLED=true
CYRANO_ENABLED=true
INTEGRATION_HUB_ENABLED=true
AUDIT_IMMUTABLE_ENABLED=true
STREAMING_ENABLED=true

# ── Gamification — RRR (Rooble n' Rumble Rewards) ───────────────────────────
GAMIFICATION_ENABLED=true
GAMIFICATION_RRR_BURN_ENABLED=true
GAMIFICATION_MOUSE_SHAKE_REQUIRED=true
GAMIFICATION_CAPTCHA_ON_SUSPICIOUS=true

# ── RRR API (cross-property points settlement) ──────────────────────────────
# REQUIRED in production for cross-property RRR balance lookups + burns.
RRR_API_BASE_URL=
RRR_API_KEY=
RRR_TIMEOUT_MS=5000

# ── eCommsZone webhook bridge (integration-hub) ─────────────────────────────
# OPTIONAL in local dev. When set, high-heat monetization events are forwarded
# to eCommsZone via webhook while still being emitted on NATS.
ECOMMSZONE_WEBHOOK_URL=
ECOMMSZONE_WEBHOOK_SECRET=
ECOMMSZONE_WEBHOOK_TIMEOUT_MS=5000

# ── Payments (Stripe) ───────────────────────────────────────────────────────
# REQUIRED for production. Use sk_test_* in dev/CI.
STRIPE_SECRET_KEY=
# REQUIRED for the Stripe webhook controller (subscription lifecycle).
STRIPE_WEBHOOK_SECRET=
# Optional: enables the Stripe sandbox E2E smoke when set; CI skips when empty.
STRIPE_TEST_KEY=

# ── Cyrano subscription tier price IDs (Stripe) ─────────────────────────────
# REQUIRED for Cyrano subscription checkout to function. Each tier has a
# monthly + annual price ID. Source these from Stripe Dashboard.
STRIPE_PRICE_SPARK_MONTHLY=
STRIPE_PRICE_SPARK_ANNUAL=
STRIPE_PRICE_FLAME_MONTHLY=
STRIPE_PRICE_FLAME_ANNUAL=
STRIPE_PRICE_INFERNO_MONTHLY=
STRIPE_PRICE_INFERNO_ANNUAL=

# ── Voice cloning (ElevenLabs) ──────────────────────────────────────────────
# REQUIRED for voice-call feature.
ELEVENLABS_API_KEY=

# ── Image generation (Flux + Banana.dev) ────────────────────────────────────
# REQUIRED for AI Twin training + photorealistic image generation.
# FLUX_API_KEY is reserved for the direct Flux API path (used when bypassing
# the Banana host); Banana.dev keys cover the standard photoreal path.
FLUX_API_KEY=
BANANA_API_KEY=
BANANA_API_ENDPOINT=https://api.banana.dev
BANANA_START_PATH=/start/v4/
BANANA_MODEL_KEY_FLUX_PRO=
BANANA_MODEL_KEY_FLUX_SCHNELL=

# ── AI Twin training tunables ───────────────────────────────────────────────
AI_TWIN_LORA_RANK=16

# ── Narrative engine ────────────────────────────────────────────────────────
NARRATIVE_MEMORY_TTL_DAYS=365
# OPTIONAL. Header name the LLM proxy uses to forward the persona ID. Default
# matches the narrative-engine convention.
NARRATIVE_PERSONA_HEADER=x-cyrano-persona-id

# ── LLM provider (narrative-engine, GateGuard moderation) ───────────────────
# REQUIRED in production for narrative LLM calls + GateGuard semantic checks.
# Pick exactly one provider — the orchestrator selects based on which is set.
# Generated by Phase 2 LLM-orchestrator directive (CYR-LLM-001).
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
LLM_DEFAULT_MODEL=claude-sonnet-4-6

# ── ML / model paths (FFS sensor scoring) ───────────────────────────────────
# OPTIONAL. Path to the local sensync ML model bundle. Defaults to the bundled
# FFS heuristic when empty.
ML_MODEL_PATH=

# ── Webhook + RBAC step-up signing ──────────────────────────────────────────
# REQUIRED. Generate with: openssl rand -hex 32
WEBHOOK_SIGNING_SECRET=
RBAC_STEP_UP_SIGNING_SECRET=

# ── Cyrano standalone UI (Next.js, port 3100) ───────────────────────────────
CYRANO_CORE_API_URL=http://localhost:3000
NEXT_PUBLIC_CYRANO_API_URL=http://localhost:3000

# ── Brand portals (Next.js, ports 3001–3006) ────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3000
